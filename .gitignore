# ─── Dependencies ─────────────────────────────────────────────
node_modules/
.npm/
.pnp.*
.yarn/cache
.yarn/install-state.gz

# ─── Build output ─────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.vite/
.turbo/
.cache/
*.tsbuildinfo

# ─── Environment & secrets ────────────────────────────────────
# NEVER commit real env files. .env.example IS committed.
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# ─── Local Postgres data (Docker volume mount) ────────────────
postgres-data/
.postgres-data/

# ─── Uploaded files (Phase 1 stores on local FS) ──────────────
# Anchor to root so we don't accidentally ignore backend/src/storage/.
/storage/
/uploads/
/backend/storage/
/backend/uploads/

# ─── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Test coverage ────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ─── IDE / editor ─────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo
*~

# ─── OS junk ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Misc ─────────────────────────────────────────────────────
*.bak
*.tmp
.tmp/
.temp/
