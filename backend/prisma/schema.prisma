// CA360 — Phase 1 schema
//
// Tables:
//   ca_firm, branches, users          (auth + tenancy)
//   clients                            (client master)
//   client_credentials                 (encrypted portal logins per client)
//   audit_log                          (append-only mutation log)
//
// Tables for Week 3+ (itr_filings, documents, activity_log) added in next batch.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────

enum UserRole {
  MANAGING_PARTNER
  PARTNER
  BRANCH_HEAD
  SENIOR_ARTICLE
  ARTICLE
  ACCOUNTANT
}

enum ClientType {
  INDIVIDUAL
  HUF
  PROPRIETORSHIP
  PARTNERSHIP
  LLP
  COMPANY
  TRUST
  AOP_BOI
  OTHER
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum Portal {
  INCOME_TAX
  GST
  TRACES
  MCA
}

// ─────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────

model CaFirm {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  pan            String?
  registrationNo String?  @map("registration_no")
  address        String?
  plan           String   @default("starter")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  branches    Branch[]
  users       User[]
  clients     Client[]
  credentials ClientCredential[]
  auditLogs   AuditLog[]

  @@map("ca_firm")
}

model Branch {
  id         String   @id @default(uuid()) @db.Uuid
  firmId     String   @map("firm_id") @db.Uuid
  name       String
  city       String
  address    String?
  headUserId String?  @map("head_user_id") @db.Uuid
  isHq       Boolean  @default(false) @map("is_hq")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  firm    CaFirm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  head    User?    @relation("BranchHead", fields: [headUserId], references: [id], onDelete: SetNull)
  users   User[]   @relation("BranchUsers")
  clients Client[]

  @@unique([firmId, name])
  @@index([firmId])
  @@map("branches")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  firmId       String    @map("firm_id") @db.Uuid
  branchId     String?   @map("branch_id") @db.Uuid
  name         String
  email        String    @unique
  mobile       String?
  role         UserRole
  passwordHash String    @map("password_hash")
  twoFaSecret  String?   @map("two_fa_secret")
  twoFaEnabled Boolean   @default(false) @map("two_fa_enabled")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  firm                  CaFirm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  branch                Branch?            @relation("BranchUsers", fields: [branchId], references: [id], onDelete: SetNull)
  branchesHeaded        Branch[]           @relation("BranchHead")
  assignedClients       Client[]           @relation("ClientAssignment")
  credentialReveals     ClientCredential[] @relation("CredentialRevealer")
  auditLogs             AuditLog[]         @relation("UserAuditLog")

  @@index([firmId])
  @@index([branchId])
  @@map("users")
}

model Client {
  id             String       @id @default(uuid()) @db.Uuid
  firmId         String       @map("firm_id") @db.Uuid
  branchId       String       @map("branch_id") @db.Uuid
  assignedUserId String?      @map("assigned_user_id") @db.Uuid
  srNo           Int          @map("sr_no")
  name           String
  fatherName     String?      @map("father_name")
  pan            String?      @db.VarChar(10)
  aadharMasked   String?      @map("aadhar_masked") @db.VarChar(14) // e.g. "XXXX-XXXX-1234"
  dob            DateTime?    @db.Date
  typeOfAssessee ClientType   @default(INDIVIDUAL) @map("type_of_assessee")
  email          String?
  mobile         String?
  address        String?
  status         ClientStatus @default(ACTIVE)
  onboardedOn    DateTime     @default(now()) @db.Date @map("onboarded_on")
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  firm        CaFirm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  branch      Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  assignedTo  User?              @relation("ClientAssignment", fields: [assignedUserId], references: [id], onDelete: SetNull)
  credentials ClientCredential[]

  @@unique([firmId, srNo])
  @@unique([firmId, pan])
  @@index([firmId])
  @@index([branchId])
  @@index([assignedUserId])
  @@index([firmId, status])
  @@index([firmId, name])
  @@map("clients")
}

model ClientCredential {
  id                   String    @id @default(uuid()) @db.Uuid
  firmId               String    @map("firm_id") @db.Uuid
  clientId             String    @map("client_id") @db.Uuid
  portal               Portal
  username             String
  encryptedPassword    String    @map("encrypted_password")
  encryptionKeyVersion Int       @default(1) @map("encryption_key_version")
  lastUpdated          DateTime  @default(now()) @map("last_updated")
  lastRevealedAt       DateTime? @map("last_revealed_at")
  lastRevealedBy       String?   @map("last_revealed_by") @db.Uuid
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  firm       CaFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client     Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  revealedBy User?  @relation("CredentialRevealer", fields: [lastRevealedBy], references: [id], onDelete: SetNull)

  @@unique([clientId, portal])
  @@index([firmId])
  @@index([clientId])
  @@map("client_credentials")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  firmId      String   @map("firm_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  action      String // CREATE | UPDATE | DELETE | REVEAL_CREDENTIAL | LOGIN | LOGOUT | etc.
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  payloadJson Json?    @map("payload_json")
  createdAt   DateTime @default(now()) @map("created_at")

  firm CaFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  user User?  @relation("UserAuditLog", fields: [userId], references: [id], onDelete: SetNull)

  @@index([firmId, createdAt])
  @@index([firmId, entityType, entityId])
  @@map("audit_log")
}
