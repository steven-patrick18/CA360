// CA360 — Phase 1 schema
//
// Tables:
//   ca_firm, branches, users          (auth + tenancy)
//   clients                            (client master)
//   client_credentials                 (encrypted portal logins per client)
//   audit_log                          (append-only mutation log)
//
// Tables for Week 3+ (itr_filings, documents, activity_log) added in next batch.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────

enum UserRole {
  MANAGING_PARTNER
  PARTNER
  BRANCH_HEAD
  SENIOR_ARTICLE
  ARTICLE
  ACCOUNTANT
}

enum ClientType {
  INDIVIDUAL
  HUF
  PROPRIETORSHIP
  PARTNERSHIP
  LLP
  COMPANY
  TRUST
  AOP_BOI
  OTHER
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum Portal {
  INCOME_TAX
  GST
  TRACES
  MCA
}

enum FilingStatus {
  PENDING
  DOCS_AWAITED
  IN_PROCESS
  READY
  FILED
  ACKNOWLEDGED
  DEFECTIVE
}

enum ItrForm {
  ITR1
  ITR2
  ITR3
  ITR4
  ITR5
  ITR6
  ITR7
}

// ─────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────

model CaFirm {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  pan            String?
  registrationNo String?  @map("registration_no")
  address        String?
  plan           String   @default("starter")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  branches    Branch[]
  users       User[]
  clients     Client[]
  credentials ClientCredential[]
  filings     ItrFiling[]
  documents   Document[]
  auditLogs   AuditLog[]

  @@map("ca_firm")
}

model Branch {
  id         String   @id @default(uuid()) @db.Uuid
  firmId     String   @map("firm_id") @db.Uuid
  name       String
  city       String
  address    String?
  headUserId String?  @map("head_user_id") @db.Uuid
  isHq       Boolean  @default(false) @map("is_hq")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  firm    CaFirm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  head    User?    @relation("BranchHead", fields: [headUserId], references: [id], onDelete: SetNull)
  users   User[]   @relation("BranchUsers")
  clients Client[]

  @@unique([firmId, name])
  @@index([firmId])
  @@map("branches")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  firmId       String    @map("firm_id") @db.Uuid
  branchId     String?   @map("branch_id") @db.Uuid
  name         String
  email        String    @unique
  mobile       String?
  role         UserRole
  passwordHash String    @map("password_hash")
  twoFaSecret  String?   @map("two_fa_secret")
  twoFaEnabled Boolean   @default(false) @map("two_fa_enabled")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  firm                  CaFirm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  branch                Branch?            @relation("BranchUsers", fields: [branchId], references: [id], onDelete: SetNull)
  branchesHeaded        Branch[]           @relation("BranchHead")
  assignedClients       Client[]           @relation("ClientAssignment")
  credentialReveals     ClientCredential[] @relation("CredentialRevealer")
  filingsPrepared       ItrFiling[]        @relation("FilingPreparer")
  filingsFiled          ItrFiling[]        @relation("FilingFiler")
  documentsUploaded     Document[]         @relation("DocumentUploader")
  auditLogs             AuditLog[]         @relation("UserAuditLog")

  @@index([firmId])
  @@index([branchId])
  @@map("users")
}

model Client {
  id             String       @id @default(uuid()) @db.Uuid
  firmId         String       @map("firm_id") @db.Uuid
  branchId       String       @map("branch_id") @db.Uuid
  assignedUserId String?      @map("assigned_user_id") @db.Uuid
  srNo           Int          @map("sr_no")
  name           String
  fatherName     String?      @map("father_name")
  pan            String?      @db.VarChar(10)
  aadharMasked   String?      @map("aadhar_masked") @db.VarChar(14) // e.g. "XXXX-XXXX-1234"
  dob            DateTime?    @db.Date
  typeOfAssessee ClientType   @default(INDIVIDUAL) @map("type_of_assessee")
  email          String?
  mobile         String?
  address        String?
  status         ClientStatus @default(ACTIVE)
  onboardedOn    DateTime     @default(now()) @db.Date @map("onboarded_on")
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  firm        CaFirm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  branch      Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  assignedTo  User?              @relation("ClientAssignment", fields: [assignedUserId], references: [id], onDelete: SetNull)
  credentials ClientCredential[]
  filings     ItrFiling[]
  documents   Document[]

  @@unique([firmId, srNo])
  @@unique([firmId, pan])
  @@index([firmId])
  @@index([branchId])
  @@index([assignedUserId])
  @@index([firmId, status])
  @@index([firmId, name])
  @@map("clients")
}

model ClientCredential {
  id                   String    @id @default(uuid()) @db.Uuid
  firmId               String    @map("firm_id") @db.Uuid
  clientId             String    @map("client_id") @db.Uuid
  portal               Portal
  username             String
  encryptedPassword    String    @map("encrypted_password")
  encryptionKeyVersion Int       @default(1) @map("encryption_key_version")
  lastUpdated          DateTime  @default(now()) @map("last_updated")
  lastRevealedAt       DateTime? @map("last_revealed_at")
  lastRevealedBy       String?   @map("last_revealed_by") @db.Uuid
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  firm       CaFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client     Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  revealedBy User?  @relation("CredentialRevealer", fields: [lastRevealedBy], references: [id], onDelete: SetNull)

  @@unique([clientId, portal])
  @@index([firmId])
  @@index([clientId])
  @@map("client_credentials")
}

model ItrFiling {
  id                String       @id @default(uuid()) @db.Uuid
  firmId            String       @map("firm_id") @db.Uuid
  clientId          String       @map("client_id") @db.Uuid
  assessmentYear    String       @map("assessment_year") @db.VarChar(7) // "2024-25"
  itrForm           ItrForm?     @map("itr_form")
  status            FilingStatus @default(PENDING)
  dueDate           DateTime?    @map("due_date") @db.Date
  filedDate         DateTime?    @map("filed_date") @db.Date
  acknowledgementNo String?      @map("acknowledgement_no")
  grossIncome       Decimal?     @map("gross_income") @db.Decimal(15, 2)
  taxPaid           Decimal?     @map("tax_paid") @db.Decimal(15, 2)
  refundAmount      Decimal?     @map("refund_amount") @db.Decimal(15, 2)
  preparedById      String?      @map("prepared_by") @db.Uuid
  filedById         String?      @map("filed_by") @db.Uuid
  remarks           String?
  details           Json?
  sourceJson        String?      @map("source_json")
  sourceFilename    String?      @map("source_filename")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  firm       CaFirm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  preparedBy User?      @relation("FilingPreparer", fields: [preparedById], references: [id], onDelete: SetNull)
  filedBy    User?      @relation("FilingFiler", fields: [filedById], references: [id], onDelete: SetNull)
  documents  Document[]

  @@unique([clientId, assessmentYear])
  @@index([firmId])
  @@index([clientId])
  @@index([firmId, status])
  @@index([firmId, assessmentYear])
  @@index([firmId, dueDate])
  @@map("itr_filings")
}

model Document {
  id           String   @id @default(uuid()) @db.Uuid
  firmId       String   @map("firm_id") @db.Uuid
  clientId     String   @map("client_id") @db.Uuid
  filingId     String?  @map("filing_id") @db.Uuid
  category     String?  @db.VarChar(60) // free-text label e.g. "Form 16", "Bank statement"
  storagePath  String   @map("storage_path") // opaque path/key handed to StorageService
  originalName String   @map("original_name")
  size         Int
  mime         String
  uploadedById String   @map("uploaded_by") @db.Uuid
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  firm       CaFirm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  filing     ItrFiling? @relation(fields: [filingId], references: [id], onDelete: SetNull)
  uploadedBy User       @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([firmId])
  @@index([clientId])
  @@index([filingId])
  @@map("documents")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  firmId      String   @map("firm_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  action      String // CREATE | UPDATE | DELETE | REVEAL_CREDENTIAL | LOGIN | LOGOUT | etc.
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  payloadJson Json?    @map("payload_json")
  createdAt   DateTime @default(now()) @map("created_at")

  firm CaFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  user User?  @relation("UserAuditLog", fields: [userId], references: [id], onDelete: SetNull)

  @@index([firmId, createdAt])
  @@index([firmId, entityType, entityId])
  @@map("audit_log")
}
