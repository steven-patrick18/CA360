# ─────────────────────────────────────────────────────────────────────────────
# CA360 — Example environment variables
#
# Copy this file to /backend/.env and fill in real values.
# NEVER commit the real .env file (it is in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
# For local Windows native Postgres after `winget install` of Postgres 15:
#   - Default user is `postgres` with the password you set during install.
#   - We create a dedicated `ca360` user + `ca360` database for the app.
DATABASE_URL="postgresql://ca360:CHANGE_ME@localhost:5432/ca360?schema=public"

# ── Backend HTTP server ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# CORS / allowed origin for the frontend dev server (Vite default).
FRONTEND_URL=http://localhost:5173

# ── JWT (auth tokens) ───────────────────────────────────────────────────────
# Generate a strong random value, e.g. in PowerShell:
#   [Convert]::ToBase64String((1..64 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── 2FA (TOTP) ──────────────────────────────────────────────────────────────
# Issuer name shown in authenticator apps (Google Authenticator, Authy, etc.)
TOTP_ISSUER=CA360

# ── Encryption (AES-256-GCM for stored client portal credentials) ───────────
# A master key from which per-firm keys are derived via HKDF.
# 32 bytes, base64-encoded. Generate in PowerShell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
MASTER_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES

# ── File storage (local filesystem in v1) ───────────────────────────────────
# Absolute or repo-relative path where uploaded documents are stored.
# In v1 this is local; the storage layer is abstracted so S3 can plug in later.
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage

# ── Seed data (first-run admin user) ────────────────────────────────────────
# Used by `npm run seed` to create the initial Managing Partner account.
SEED_FIRM_NAME="My CA Firm"
SEED_ADMIN_EMAIL=admin@ca360.local
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME="Managing Partner"
